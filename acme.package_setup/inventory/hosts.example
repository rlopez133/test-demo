# Example inventory file
# Copy to inventory/hosts and customize for your environment

[all]
localhost ansible_connection=local

# Debian/Ubuntu systems
[debian_family]
# ubuntu_host ansible_host=192.168.1.100 ansible_user=ubuntu
# debian_host ansible_host=192.168.1.101 ansible_user=debian

# RHEL/Rocky/Alma systems
[rhel_family]
# rhel_host ansible_host=192.168.1.200 ansible_user=ec2-user
# rocky_host ansible_host=192.168.1.201 ansible_user=rocky

# Common variables
[all:vars]
ansible_user=root
ansible_python_interpreter=/usr/bin/python3
ansible_become=true
ansible_become_method=sudo
